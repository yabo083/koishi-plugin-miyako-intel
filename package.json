{
  "name": "koishi-plugin-miyako-intel",
  "version": "1.1.1",
  "description": "Koishi plugin: Miyako-branded game intel cards with daily cache and scheduled push.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "keywords": [
    "koishi",
    "koishi-plugin",
    "arknights",
    "prts",
    "wiki",
    "miyako",
    "daily",
    "intel"
  ],
  "author": "miyako",
  "homepage": "https://github.com/yabo083/koishi-plugin-miyako-intel",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yabo083/koishi-plugin-miyako-intel.git"
  },
  "bugs": {
    "url": "https://github.com/yabo083/koishi-plugin-miyako-intel/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test tests/*.test.cjs",
    "prepublishOnly": "npm run build",
    "pub": "npm run build && npm publish --access public"
  },
  "peerDependencies": {
    "koishi": "^4.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "typescript": "^5.8.3"
  },
  "koishi": {
    "description": {
      "zh": "Miyako 游戏情报插件：每日缓存并推送资料源情报整合图。"
    },
    "service": {
      "optional": [
        "puppeteer"
      ]
    }
  }
}
